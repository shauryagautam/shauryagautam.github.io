---
const clients = [
  {
    name: "Dana Trails",
    description: "Premium Travel Agency specializing in bespoke experiences.",
    url: "https://danatrails.social/",
    category: "Travel",
    icon: "🏔️"
  },
  {
    name: "PC School",
    description: "Elite 1:1 personal coaching for high-performance individuals.",
    url: "https://pcschool.in/",
    category: "Coaching",
    icon: "🎓"
  },
  {
    name: "Aarivu",
    description: "Next-generation social media platform for knowledge sharing.",
    url: "https://aarivu.live/",
    category: "Social Media",
    icon: "📱"
  }
];
---

<section id="clients" class="py-24 bg-white dark:bg-neutral-900/30 border-y border-neutral-100 dark:border-neutral-800">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16 text-center">
      <span class="text-xs font-bold uppercase tracking-[0.3em] text-accent mb-4 block">Portfolio</span>
      <h2 class="text-4xl md:text-5xl font-serif font-bold mb-4">Trusted by Shaurya<span class="text-accent">&</span>Co</h2>
      <p class="text-neutral-500 text-lg max-w-2xl mx-auto">Scaling disruptive startups and agencies through product-led growth and engineering excellence.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {clients.map((client) => (
        <a 
          href={client.url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group relative p-8 rounded-3xl border border-neutral-100 dark:border-neutral-800 bg-white/50 dark:bg-neutral-950/20 backdrop-blur-sm hover:border-accent transition-all duration-500 hover:-translate-y-2 overflow-hidden"
        >
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="text-6xl grayscale group-hover:grayscale-0 transition-all duration-500">{client.icon}</span>
          </div>
          
          <div class="relative z-10">
            <div class="text-xs font-bold uppercase tracking-widest text-accent mb-4">{client.category}</div>
            <h3 class="text-2xl font-serif font-bold mb-3 group-hover:text-accent transition-colors">{client.name}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed mb-6">{client.description}</p>
            
            <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
              Visit Project 
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
          </div>

          <div class="absolute inset-0 bg-linear-to-br from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </a>
      ))}
    </div>
  </div>
</section>
