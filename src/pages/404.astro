---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { ArrowLeft, Home, Search } from 'lucide-react';
---

<Layout title="404 - Page Not Found | Shaurya Kumar">
  <Navbar />
  <main class="min-h-screen flex items-center justify-center px-4 bg-white dark:bg-neutral-900 pt-20">
    <div class="text-center max-w-2xl">
      <!-- 404 Number with Animation -->
      <div class="mb-8">
        <h1 class="text-8xl md:text-9xl font-bold text-accent/20 dark:text-accent/10 mb-4">
          404
        </h1>
        <div class="relative">
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 dark:text-white mb-4">
            Page Not Found
          </h2>
          <div class="absolute -top-2 -right-2 w-3 h-3 bg-accent rounded-full animate-pulse"></div>
        </div>
      </div>

      <!-- Error Description -->
      <p class="text-xl text-neutral-600 dark:text-neutral-400 mb-8 max-w-md mx-auto">
        The page you're looking for seems to have vanished into the digital void. 
        Let's get you back on track.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
        <a 
          href="/" 
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent text-white rounded-lg hover:bg-accent/90 transition-all duration-200 hover:scale-105"
        >
          <Home className="w-4 h-4" />
          Go Home
        </a>
        
        <button 
          onclick="history.back()" 
          class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all duration-200"
        >
          <ArrowLeft className="w-4 h-4" />
          Go Back
        </button>
      </div>

      <!-- Search Suggestions -->
      <div class="border-t border-neutral-200 dark:border-neutral-800 pt-8">
        <h3 class="text-lg font-semibold text-neutral-900 dark:text-white mb-4">
          Maybe you're looking for:
        </h3>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left">
          <a 
            href="#work" 
            class="flex items-center gap-3 p-3 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors group"
          >
            <div class="w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center group-hover:bg-accent/20 transition-colors">
              <Search className="w-4 h-4 text-accent" />
            </div>
            <div>
              <div class="font-medium text-neutral-900 dark:text-white">Work & Projects</div>
              <div class="text-sm text-neutral-600 dark:text-neutral-400">Explore my portfolio</div>
            </div>
          </a>
          
          <a 
            href="#about" 
            class="flex items-center gap-3 p-3 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors group"
          >
            <div class="w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center group-hover:bg-accent/20 transition-colors">
              <Search className="w-4 h-4 text-accent" />
            </div>
            <div>
              <div class="font-medium text-neutral-900 dark:text-white">About Me</div>
              <div class="text-sm text-neutral-600 dark:text-neutral-400">Learn more about my background</div>
            </div>
          </a>
          
          <a 
            href="#contact" 
            class="flex items-center gap-3 p-3 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors group"
          >
            <div class="w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center group-hover:bg-accent/20 transition-colors">
              <Search className="w-4 h-4 text-accent" />
            </div>
            <div>
              <div class="font-medium text-neutral-900 dark:text-white">Get in Touch</div>
              <div class="text-sm text-neutral-600 dark:text-neutral-400">Reach out for collaborations</div>
            </div>
          </a>
          
          <a 
            href="mailto:shauryagautam139@outlook.com" 
            class="flex items-center gap-3 p-3 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors group"
          >
            <div class="w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center group-hover:bg-accent/20 transition-colors">
              <Search className="w-4 h-4 text-accent" />
            </div>
            <div>
              <div class="font-medium text-neutral-900 dark:text-white">Report Issue</div>
              <div class="text-sm text-neutral-600 dark:text-neutral-400">Let me know about broken links</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Fun Animation -->
      <div class="mt-12 relative">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-32 h-32 bg-accent/5 rounded-full blur-2xl animate-pulse"></div>
        </div>
        <div class="relative text-sm text-neutral-500 dark:text-neutral-400">
          Error code: 404 • Page lost in cyberspace 🚀
        </div>
      </div>
    </div>
  </main>
</Layout>
